# Template for dev:cloud-db mode (docs/01) — copy to .env.cloud-db (git-ignored)
# and fill from the STAGING Supabase project dashboard (docs/07 Part 2).
# NEVER put production values here.
SUPABASE_URL=https://<staging-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:<db-password>@db.<staging-ref>.supabase.co:5432/postgres

# Optional extra guard: set to the PRODUCTION project ref; the script refuses
# to start if SUPABASE_URL contains it.
PRODUCTION_PROJECT_REF=

# Type `yes` only after verifying every value above is the staging project.
STAGING_CONFIRMED=
