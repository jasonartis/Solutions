# Keep the worker image's build context small and secret-free.
node_modules
**/node_modules
**/dist
**/.next
**/.turbo
**/test-results
**/playwright-report
.git
supabase/.temp

# Secrets and local-only files must NEVER enter an image.
.env
.env.*
!.env.example
!.env.deploy.example
!.env.cloud-db.example
apps/worker/.env
apps/web/.env.local
client-materials
