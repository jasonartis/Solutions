{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@platform/core": ["../../packages/platform/src/index.ts"],
      "@platform/core/*": ["../../packages/platform/src/*"],
      "@platform/db": ["../../packages/db/src/index.ts"],
      "@platform/db/*": ["../../packages/db/src/*"],
      "@modules/synagogue-schedules": ["../../modules/synagogue-schedules/src/index.ts"],
      "@modules/synagogue-schedules/*": ["../../modules/synagogue-schedules/*"],
      "@modules/classroom": ["../../modules/classroom/src/index.ts"],
      "@modules/classroom/*": ["../../modules/classroom/*"],
      "@modules/matchmaking": ["../../modules/matchmaking/src/index.ts"],
      "@modules/matchmaking/*": ["../../modules/matchmaking/*"],
      "@modules/nail-salon/*": ["../../modules/nail-salon/*"],
      "@modules/speed-dating": ["../../modules/speed-dating/src/index.ts"],
      "@modules/speed-dating/*": ["../../modules/speed-dating/*"],
      "@modules/sample/*": ["../../modules/sample/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
