# =============================================================================
# EXTERNAL ACCOUNTS — credential store (TEMPLATE / example)
# =============================================================================
# Copy this file to `.env.accounts` (git-ignored) and fill in the real
# usernames + passwords. The human-readable description of WHAT each account
# is and WHERE to sign in lives in docs/14-external-accounts.md — this file
# holds only the credentials.
#
# NEVER commit `.env.accounts`. Only THIS `.example` (with blank/placeholder
# values) is committed. Keep the real file backed up in your password manager
# too — treat this as a convenience index, not the only copy.
#
# When a NEW external service is added to the platform, add its block here AND
# in `.env.accounts`, and add a row to docs/14-external-accounts.md.
# =============================================================================

# --- GitHub (source control + CI/CD) ----------------------------------------
GITHUB_USERNAME=
GITHUB_PASSWORD=
# Personal access token if you use one for CLI/push (optional):
GITHUB_PAT=

# --- Vercel (production web hosting) ----------------------------------------
# Usually "Sign in with GitHub" — if so, put "via GitHub" as the password note.
VERCEL_LOGIN_EMAIL=
VERCEL_PASSWORD=

# --- Supabase (production database / auth / storage) ------------------------
# Usually "Sign in with GitHub". The DB password + API keys are the sensitive
# bits (also mirrored in .env.deploy for the CLI).
SUPABASE_LOGIN_EMAIL=
SUPABASE_PASSWORD=
SUPABASE_DB_PASSWORD=

# --- Platform app superadmin (the Solutions Platform site itself) -----------
# The in-app superadmin login at https://solutions-platform.vercel.app/login
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
# The password used when seeding the demo world into production (DEMO_PASSWORD):
PROD_DEMO_PASSWORD=

# --- UptimeRobot (uptime monitoring + keep-alive ping) ----------------------
UPTIMEROBOT_LOGIN_EMAIL=
UPTIMEROBOT_PASSWORD=

# --- myzmanim.com (zmanim API for the synagogue-schedules module) -----------
MYZMANIM_LOGIN_EMAIL=
MYZMANIM_PASSWORD=
MYZMANIM_API_KEY=

# --- Google (platform email identity) ---------------------------------------
# The Google account used as the platform identity / SSO into the consoles above.
GOOGLE_ACCOUNT_EMAIL=
GOOGLE_ACCOUNT_PASSWORD=

# =============================================================================
# PLANNED / not created yet — uncomment + fill when you sign up (see docs/14).
# =============================================================================
