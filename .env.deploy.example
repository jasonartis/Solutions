# Production deploy credentials — copy to `.env.deploy` (git-ignored) and fill in.
# Claude uses this file locally to link the Supabase project and push migrations.
# Values come from the Supabase dashboard (docs/07 Part 2). NEVER commit .env.deploy.

# Project ref from the URL (already known): jbjqrkxdoiolwlglvoki
SUPABASE_PROJECT_REF=jbjqrkxdoiolwlglvoki

# supabase.com -> click your avatar (top right) -> Account settings -> Access Tokens
# -> Generate new token, name it "cli"
SUPABASE_ACCESS_TOKEN=

# The database password you saved when creating the project
# (Project Settings -> Database -> you can also reset it there if lost)
SUPABASE_DB_PASSWORD=

# Project Settings -> API Keys
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
