# Copy to worker.env on the VPS and fill in real values. worker.env is
# git-ignored — it holds the service-role key and must never be committed.

# Postgres connection for pg-boss. Use the SESSION POOLER string from the
# Supabase dashboard (Project Settings -> Database -> Connection string ->
# "Session pooler", port 5432) — it has IPv4; the direct connection is
# IPv6-only without an addon.
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# The production project's URL + service-role key (Project Settings -> API).
# The service-role key bypasses RLS — worker only, never the web app.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Optional: myzmanim credentials once the auth issue is resolved (module 3 SPEC).
# MYZMANIM_USER=
# MYZMANIM_KEY=
